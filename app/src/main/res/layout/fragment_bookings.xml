<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/coastal_fog">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:background="@color/coastal_fog">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Hotels"
            android:textSize="32sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/charcoal_black"
            android:textStyle="bold"
            android:letterSpacing="-0.02"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Check Bookings against your Hotels"
            android:textSize="16sp"
            android:textColor="@color/grey_text"
            android:fontFamily="sans-serif"/>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHotels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="24dp"
            android:scrollbars="vertical"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/hotel_item" />

        <TextView
            android:id="@+id/tvNoHotels"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No hotels found"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/grey_text"
            android:drawableTop="@drawable/ic_search"
            android:drawableTint="@color/grey_text"
            android:drawablePadding="16dp"
            android:gravity="center"
            android:visibility="gone"
            tools:visibility="visible" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/deep_turquoise"
            android:visibility="gone" />

    </FrameLayout>
</LinearLayout>